PORT=3000
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
LOG_LEVEL=info
DEMO_MODE=false
DECISION_LOGGING_ENABLED=false
ENABLE_UNSAFE_SCREENING=true
ENABLE_OUTPUT_GUARDRAILS=true
FORCE_ABSTAIN_ON_LOW_CONFIDENCE=true
# Local-demo-only overrides. Leave unset for the default safe runtime.
INFERENCE_MODEL_OVERRIDE=
FETCH_TIMEOUT_MS=
MAX_FETCH_SIZE_MB=
MAX_OUTPUT_TOKENS=
IMAGE_FETCH_REDIRECT_LIMIT=3
IMAGE_FETCH_MAX_CONTENT_LENGTH_BYTES=10485760
IMAGE_FETCH_CONNECT_TIMEOUT_MS=2000
IMAGE_FETCH_READ_TIMEOUT_MS=5000
